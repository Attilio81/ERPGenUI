# Connessione al database del gestionale (SQL Server, sola lettura)
DB_CONN=Driver={ODBC Driver 17 for SQL Server};Server=HOST\ISTANZA;Database=NOMEDB;UID=utente;PWD=password;Encrypt=yes;TrustServerCertificate=yes

# Chiave API DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Codice ditta (multitenant: una ditta per deploy). Default: VITC
CODDITT=VITC

# Guardia PII (anonimizza il testo utente prima del LLM). Default: off.
# Richiede il microservizio pii-service attivo (vedi ../pii-service/README.md).
PII_GUARD=off
PII_URL=http://127.0.0.1:5005
