# Connessione al database del gestionale (SQL Server, sola lettura)
DB_CONN=Driver={ODBC Driver 17 for SQL Server};Server=HOST\ISTANZA;Database=NOMEDB;UID=utente;PWD=password;Encrypt=yes;TrustServerCertificate=yes

# --- Modello LLM (provider selezionabile) ---
# AI_PROVIDER: mistral (UE, GDPR-compliant · consigliato prod) | deepseek (Cina, dev) | local
AI_PROVIDER=deepseek

# Mistral La Plateforme (UE) — richiede: pip install mistralai
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MISTRAL_MODEL=mistral-small-latest

# DeepSeek (https://platform.deepseek.com) — economico ma server in Cina (non GDPR)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM locale (self-host OpenAI-compatibile: Ollama/LM Studio/vLLM)
# LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_MODEL=qwen2.5

# Codice ditta (multitenant: una ditta per deploy). Default: VITC
CODDITT=VITC

# Guardia PII (anonimizza il testo utente prima del LLM). Default: off.
# Richiede il microservizio pii-service attivo (vedi ../pii-service/README.md).
PII_GUARD=off
PII_URL=http://127.0.0.1:5005
