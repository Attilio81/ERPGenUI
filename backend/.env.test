# Config per il DB di TEST (vedi ../test-db/). Copia in .env oppure:
#   copy backend\.env.test backend\.env    (Windows)
# poi metti la TUA chiave LLM sotto (o usa AI_PROVIDER=local con Ollama).

# --- DB di test (container SQL Server 2022, vedi test-db/docker-compose.yml) ---
DB_CONN=Driver={ODBC Driver 17 for SQL Server};Server=localhost,1433;Database=ERPTEST;UID=sa;PWD=Test_Str0ng!Pass;Encrypt=yes;TrustServerCertificate=yes
CODDITT=VITC

# --- LLM: default locale (Ollama/LM Studio), nessuna chiave cloud richiesta ---
# Avvia p.es. Ollama:  ollama run qwen2.5   (poi lascia questi valori)
AI_PROVIDER=local
LOCAL_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL=qwen2.5

# In alternativa usa un provider cloud mettendo la tua chiave e AI_PROVIDER:
# AI_PROVIDER=mistral
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Guardia PII: spenta in test.
PII_GUARD=off
