# Token Hugging Face (write) per aprire la PR sul dataset.
# NON committare il .env vero (i .env sono gia' gitignorati con **/.env).
#
# ATTENZIONE: lo script legge il .env dalla ROOT del CLONE rizzo-pii, NON da qui.
# Quindi copia questo file come  <clone-rizzo-pii>/.env  e mettici il token,
# oppure (consigliato) usa  `hf auth login`  che salva fuori dal repo.

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
